# Fraud Detection System - Environment Variables
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Database Configuration
DATABASE_PATH=database/fraud_detection.db
DATABASE_URL=sqlite:///database/fraud_detection.db

# Model Configuration
MODELS_PATH=models
MODEL_UPDATE_INTERVAL=86400

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Feature Flags
ENABLE_ANALYTICS=True
ENABLE_ALERTS=True

# External Services (if integrating with third-party services)
# POWERBI_API_KEY=your-powerbi-api-key
# SLACK_WEBHOOK_URL=your-slack-webhook-url
